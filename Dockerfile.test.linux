# Dockerfile for running the certz test suite on Linux (Ubuntu 22.04)
# Verifies the linux-x64 self-contained executable runs correctly on Linux
# Includes ca-certificates so trust store tests (update-ca-certificates) work

FROM mcr.microsoft.com/powershell:lts-ubuntu-22.04

WORKDIR /app

# Install ca-certificates for LocalMachine trust store tests
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

ENV DOTNET_ENVIRONMENT=Test

# Copy the Linux binary and test scripts
# Prerequisite: pwsh -File build-debug.ps1
COPY debug/linux-x64/certz ./
COPY test/ ./test/

RUN chmod +x /app/certz && \
    mkdir -p /app/test-results

# Default command runs the full test suite
ENTRYPOINT ["pwsh", "-File", "./test/test-all.ps1"]
CMD ["-Verbose"]
