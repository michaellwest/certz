# Dockerfile for running certz tests in a Windows container
# Requires Windows containers to be enabled in Docker Desktop

FROM mcr.microsoft.com/dotnet/sdk:10.0-nanoserver-ltsc2022 AS base
WORKDIR /app

# Switch to Administrator for certificate operations
USER ContainerAdministrator

# Set environment variable to indicate we're in a container
ENV DOTNET_ENVIRONMENT=Test

# Copy the test script and built executables
COPY docker/tools/certz.exe ./
COPY docker/tools/certz.pdb ./
COPY test-all.ps1 ./

# Default command runs the test suite
ENTRYPOINT ["pwsh", "-File", "./test-all.ps1"]
CMD ["-Verbose"]
